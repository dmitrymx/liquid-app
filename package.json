{
  "name": "liquid-app",
  "version": "1.7.0",
  "description": "Liquid App — Premium System Optimizer for Windows 11 in Liquid Glass style",
  "main": "./out/main/index.js",
  "author": "Максимов Д.А. <@dmitrymx>",
  "homepage": "https://mxmvdev.ru",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "electron-vite": "^5.0.0",
    "i18next": "^25.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.3",
    "react-router-dom": "^7.5.3",
    "recharts": "^2.15.3",
    "systeminformation": "^5.25.11",
    "vite": "^6.4.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.15",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "ru.mxmvdev.liquidapp",
    "productName": "Liquid App",
    "copyright": "Copyright © 2026 Максимов Д.А. — mxmvdev.ru",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "fileAssociations": [],
      "legalTrademarks": "Liquid App™ — Premium System Optimizer",
      "extraResources": [
        {
          "from": "resources/bin",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Liquid App",
      "installerLanguages": [
        "en_US",
        "ru_RU"
      ],
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "LiquidApp-${version}-portable.exe",
      "requestExecutionLevel": "admin"
    }
  }
}
